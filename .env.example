# ------------------------------------------------------------------------------
# FinSight RAG Configuration - EXAMPLE TEMPLATE
# Copy this file to `.env` and fill in your actual values.
# Do NOT commit your active `.env` file containing secrets to Git!
# ------------------------------------------------------------------------------

# Project Configuration
PROJECT_NAME="FinSight RAG API"

# Security & Authentication
# Generate a secure random secret key for production environments
SECRET_KEY="super-secret-key-for-finsight-rag-development-1234567890"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database Connection
DATABASE_URL="sqlite:///./finrag.db"

# Redis & Celery Message Broker
REDIS_URL="redis://localhost:6379/0"

# LLM Providers (Claude by Anthropic)
# Replace with your actual Claude API key
# If left blank, mock/fallback mock responses will be used in development
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-20250514"

# Persistence Directories
PERSIST_DIR="./persist"
UPLOAD_DIR="./persist/uploads"
INDEX_DIR="./persist/indices"
